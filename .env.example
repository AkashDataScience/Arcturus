# Copy this file to .env and fill real values locally.
# Never commit .env with real secrets.

GEMINI_API_KEY=

# Gateway admin secret for /api/v1/keys* management endpoints.
# Must be explicitly set per environment. No default/fallback is used.
ARCTURUS_GATEWAY_ADMIN_KEY=

# Gateway webhook signing secret for /api/v1/webhooks/inbound/*.
# Must be explicitly set for inbound signature verification (fail-closed when unset).
ARCTURUS_GATEWAY_WEBHOOK_SIGNING_SECRET=

# Telegram channel adapter
TELEGRAM_TOKEN=

# Slack channel adapter
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Discord channel adapter
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

# WhatsApp Baileys bridge (whatsapp_bridge/)
# URL of the local Node.js bridge HTTP server (must be running separately)
WHATSAPP_BRIDGE_URL=http://localhost:3001
# Shared HMAC-SHA256 secret for bridge ↔ FastAPI authentication
# Leave empty to disable signature verification (dev mode only)
WHATSAPP_BRIDGE_SECRET=

# Google Chat channel adapter
# Webhook mode (simple — no GCP project needed): set GOOGLE_CHAT_WEBHOOK_URL only.
# Service account mode (full API access): set GOOGLE_CHAT_SERVICE_ACCOUNT_TOKEN.
# Get webhook URL from: Google Chat Space → Manage webhooks → Add webhook
GOOGLE_CHAT_WEBHOOK_URL=
# OAuth2 bearer token from service account (for full Chat API access)
GOOGLE_CHAT_SERVICE_ACCOUNT_TOKEN=
# Verification token for validating inbound events (from Google Cloud Console)
# Leave empty to disable token verification (dev mode only)
GOOGLE_CHAT_VERIFICATION_TOKEN=

# iMessage / BlueBubbles channel adapter
# Requires BlueBubbles server (https://bluebubbles.app) running on a Mac with iMessage.
# BlueBubbles settings → Private API + Webhook → add http://<host>:8000/api/nexus/imessage/inbound
BLUEBUBBLES_URL=http://localhost:1234
BLUEBUBBLES_PASSWORD=
# Optional: shared HMAC-SHA256 secret for inbound webhook auth (set in BlueBubbles webhooks)
BLUEBUBBLES_WEBHOOK_SECRET=

# Arcturus base URL (used by create_runs_agent to call the local runs API)
ARCTURUS_BASE_URL=http://localhost:8000
